# 7. Plotting


# 34  Function to plot mean distances with SEM and individual points
def plot_with_matplotlib(cn_data, gr_data, p_value, test_name):
    groups = ['CN', 'GR']
    # 35  Calculate mean
    means = [np.mean(cn_data), np.mean(gr_data)]
    # 36  Calculate standard error of mean (SEM)
    sems = [np.std(cn_data, ddof=1)/np.sqrt(len(cn_data)),
            np.std(gr_data, ddof=1)/np.sqrt(len(gr_data))]
    # 37  Create figure
    fig, ax = plt.subplots(figsize=(8,6))
    bar_colors = ['blue', 'red']
    # 38  Plot bar graph
    ax.bar(groups, means, yerr=sems, capsize=10, color=bar_colors, alpha=0.7)
    # 39  Overlay individual data points with jitter
    jitter_strength = 0.08
    for i, data in enumerate([cn_data, gr_data]):
        x = np.random.normal(i, jitter_strength, size=len(data))
        ax.scatter(x, data, color='black', alpha=0.7)
    # 40  Label axes and title
    ax.set_ylabel('Total Distance (pixels)')
    ax.set_title(f'Total Distance by Group ({test_name}, p={p_value:.3f})')
    plt.tight_layout()
    plt.show()


# 8. Main analysis


# 41  Main function to run the analysis
def main():
    # 42  Process CN folder
    cn_distances = process_folder(cn_folder)
    # 43  Process GR folder
    gr_distances = process_folder(gr_folder)
    # 44  Shapiro-Wilk normality test
    w_cn, p_cn = shapiro(cn_distances)
    w_gr, p_gr = shapiro(gr_distances)
    print(f"Shapiro CN: W={w_cn:.3f}, p={p_cn:.3f}")
    print(f"Shapiro GR: W={w_gr:.3f}, p={p_gr:.3f}")
    # 45  Descriptive statistics
    mean_cn, sd_cn = np.mean(cn_distances), np.std(cn_distances, ddof=1)
    sem_cn = sd_cn / np.sqrt(len(cn_distances))
    mean_gr, sd_gr = np.mean(gr_distances), np.std(gr_distances, ddof=1)
    sem_gr = sd_gr / np.sqrt(len(gr_distances))
    print(f"CN: Mean={mean_cn:.3f}, SD={sd_cn:.3f}, SEM={sem_cn:.3f}")
    print(f"GR: Mean={mean_gr:.3f}, SD={sd_gr:.3f}, SEM={sem_gr:.3f}")
    # 46  Decide statistical test based on normality
    alpha = 0.05
    if p_cn > alpha and p_gr > alpha:
        stat, p_test = ttest_ind(cn_distances, gr_distances, equal_var=False)
        test_name = 'Independent t-test'
    else:
        stat, p_test = mannwhitneyu(cn_distances, gr_distances, alternative='two-sided')
        test_name = 'Mann-Whitney U test'
    print(f"{test_name}: stat={stat:.3f}, p={p_test:.3f}")
    # 47  Save results for MATLAB
    savemat('total_distances.mat', {'cn_distances': cn_distances,
                                    'gr_distances': gr_distances})
    print("Saved total_distances.mat")
    # 48  Plot results
    plot_with_matplotlib(cn_distances, gr_distances, p_test, test_name)


# 9. Run


# 49  Execute main function
if __name__ == "__main__":
    main()
