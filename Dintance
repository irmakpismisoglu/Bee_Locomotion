# 3. Read DLC CSV


# 6  Function to read DLC CSV with multi-level headers
def read_dlc_csv(filepath, individual, bodypart):
    # 7  Read CSV file (4-level header: scorer, individual, bodypart, coords)
    df = pd.read_csv(filepath, header=[0,1,2,3], low_memory=False)
    # 8  Extract the scorer name (first level of header)
    same_FN = df.columns.levels[0][0]
    # 9  Extract x and y coordinates for the specified bee and bodypart
    x = df[(same_FN, individual, bodypart, 'x')].values
    y = df[(same_FN, individual, bodypart, 'y')].values
    # 10 Return dataframe, coordinates, and scorer name
    return df, x, y, same_FN

# 4. Trajectory filtering

# 11  Function to filter unrealistic trajectories
def filter_xy(x, y, center1, center2, radius, max_jump=70):
    # 12  Distance from top center
    dist1 = np.sqrt((x - center1[0])**2 + (y - center1[1])**2)
    # 13  Distance from bottom center
    dist2 = np.sqrt((x - center2[0])**2 + (y - center2[1])**2)
    # 14  Keep points within the radius of either center
    mask = (dist1 <= radius) | (dist2 <= radius)
    x, y = np.where(mask, x, np.nan), np.where(mask, y, np.nan)
    # 15  Compute frame-to-frame differences
    dx = np.diff(x)
    dy = np.diff(y)
    dist = np.sqrt(dx**2 + dy**2)
    # 16  Detect jumps larger than max_jump pixels
    jump_mask = dist > max_jump
    jump_mask = np.insert(jump_mask, 0, False)  # First frame has no diff
    x[jump_mask] = np.nan
    y[jump_mask] = np.nan
    # 17  Return filtered coordinates
    return x, y

# 5. Compute total distance 


# 18  Function to calculate total distance traveled
def calc_total_distance(df, same_FN, x, y, center1, center2, radius):
    # 19  Filter the trajectory
    x, y = filter_xy(x, y, center1, center2, radius, max_jump=max_jump)
    # 20  Compute differences
    dx = np.diff(x)
    dy = np.diff(y)
    # 21  Euclidean distances
    dist = np.sqrt(dx**2 + dy**2)
    # 22  Remove distances exceeding max_jump
    dist[dist > max_jump] = np.nan
    # 23  Sum distances ignoring NaNs
    return np.nansum(dist)


